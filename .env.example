# ==========================================
# 🤖 ІНТЕГРАЦІЇ З МЕСЕНДЖЕРАМИ
# ==========================================
TELEGRAM_BOT_TOKEN="твій_токен_від_botfather"

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_WEBHOOK_SECRET=your_discord_webhook_secret_here

# ─── Web chat API (React frontend -> FastAPI) ────────────────────────────────
WEBCHAT_API_KEY=your_webchat_api_key_here

# ─── Web app ──────────────────────────────────────────────────────────────────
WEB_APP_URL=http://localhost:5173

# Enabled channels (comma-separated): telegram,slack,discord,web
ENABLED_CHANNELS=telegram,slack,discord,web

# Public URL of your server (for webhook registration)
WEBHOOK_URL=https://your-domain.com

# ==========================================
# 🧠 МОДЕЛІ ШТУЧНОГО ІНТЕЛЕКТУ (LiteLLM)
# ==========================================
GEMINI_API_KEY="AIzaSy...твій_ключ_від_Google_AI_Studio"
# Опціонально для інших моделей:
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gemini-2.0-flash"

# ==========================================
# 🎙️ РОЗПІЗНАВАННЯ ГОЛОСУ (STT)
# ==========================================
GROQ_API_KEY="gsk_...твій_ключ_від_Groq_для_Whisper"

# ==========================================
# 🗄️ БАЗА ДАНИХ
# ==========================================
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="wallet_calendar"
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/wallet_calendar"
DATABASE_URL_DOCKER="postgresql+psycopg2://postgres:postgres@db:5432/wallet_calendar"

# Frontend dev-in-container file watching (Windows-friendly)
CHOKIDAR_USEPOLLING="true"

# ==========================================
# 🧪 РЕЖИМ РОЗРОБКИ
# ==========================================
# true = stub Google Sheets writes (useful until Google OAuth is configured)
FINANCE_STUB_MODE="false"

# ==========================================
# 📅 GOOGLE API (OAuth 2.0) - ПРЯМІ ЗМІННІ
# ==========================================
# Вставлено твої реальні дані з JSON:
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_PROJECT_ID="your_google_project_id"
GOOGLE_REDIRECT_URI="http://localhost:8000/auth/google/callback"

GOOGLE_TEMPLATE_SPREADSHEET_ID=

# ==========================================
# 🔐 БЕЗПЕКА ТА СЕСІЇ
# ==========================================
# Сюди впиши будь-який випадковий довгий рядок (для безпеки FastAPI)
SECRET_KEY="super-secret-random-string-generate-your-own"
